# ==========================================
# 인스타그램 자동 콘텐츠 생성 및 게시 설정 파일
# 이 파일을 복사하여 '.env' 파일로 이름을 변경한 뒤 사용하세요.
# ==========================================

# 1. Google Gemini API 설정
GEMINI_API_KEY=your_gemini_api_key_here

# 2. 인스타그램 계정 정보 (옵션 A)
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# 3. 2단계 인증(2FA) 백업 키 (옵션 - 필요한 경우 사용)
INSTAGRAM_2FA_SEED=

# 4. 로컬 대시보드 서버 설정
PORT=8000
HOST=127.0.0.1
